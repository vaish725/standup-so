# Copy this file to .env.local and fill in your keys. Do NOT commit .env.local to git.

# ── Anthropic (recommended per PRD) ──────────────────────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6   # default

# ── OpenAI (alternative) ──────────────────────────────────────────────────────
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini            # default

# ── Generic proxy (any provider) ─────────────────────────────────────────────
# AI_API_KEY=
# AI_API_URL=https://your-proxy-endpoint/generate

# ── Novus analytics ───────────────────────────────────────────────────────────
# NEXT_PUBLIC_NOVUS_KEY=
